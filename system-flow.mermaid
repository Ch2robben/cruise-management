flowchart TD
    subgraph A["1. 系统初始化"]
        A1["管理员注册企业账号"] --> A2["登录系统"]
        A2 --> A3["系统设置：创建角色"]
        A3 --> A4["系统设置：创建用户并分配角色"]
        A4 --> A5["系统设置：配置菜单与数据字典"]
    end

    subgraph B["2. 基础资源录入"]
        B1["港口管理：录入国内港口<br/>（名称/编码/城市）"] --> B2["景点管理：录入景点并关联港口"]
        B2 --> B3["航线管理：创建航线<br/>（起港→途中港→止港，配置航距）"]
    end

    subgraph C["3. 船舶与舱房配置"]
        C1["游轮管理：三步向导创建游轮"] --> C1a["Step1 基本信息<br/>（标识/规格/设施/联系人）"]
        C1a --> C1b["Step2 甲板信息<br/>（根据层数自动生成甲板区块）"]
        C1b --> C1c["Step3 舱房类型<br/>（rowSpan嵌套表配置各甲板舱房）"]
        C1c --> C2["房间管理：批量生成房间"]
        C2 --> C2a["Step1 命名规则<br/>（前缀+序号范围+补零+排除号）"]
        C2a --> C2b["Step2 预览微调<br/>（修改房间号/位置/删减）"]
    end

    subgraph D["4. 产品与票务配置"]
        D1["产品管理：创建产品"] --> D1a["选择航线→自动填充上下水/时长/里程"]
        D1a --> D1b["选择游轮→自动关联舱房类型"]
        D1b --> D1c["C(n,2)航段自动生成<br/>（起港→途中港→止港组合）"]
        D1c --> D1d["基准价配置：航段×舱房定价"]
        D1d --> D2["票类管理：配置票务规则"]
        D2 --> D2a["入住类型（成人/儿童/婴儿）+ 价格系数"]
        D2a --> D2b["拼房规则（增减元/%）"]
        D2b --> D2c["加床规则（增减元/%）"]
        D2c --> D2d["小费规则（不收取/按天/按人/按房）"]
    end

    subgraph E["5. 设施资源池"]
        E1["设施管理：录入通用设施<br/>（分类/收费类型/营业时间）"] --> E2["设施独立于船舶管理<br/>供后续模块引用"]
    end

    subgraph F["6. 航次运营"]
        F1["航次模板：创建运营模板"] --> F1a["Tab1 航次库存<br/>（选产品→自动填充船舱库存）"]
        F1a --> F1b["Tab2 航次行程<br/>（选产品→自动填充航线港口<br/>配置每港主题活动/地接社）"]
        F1b --> F1c["Tab3 航次定金<br/>（市场类别×定金规则）"]
        F1c --> F2["航次列表：生成航次"]
        F2 --> F2a["选产品→选模板→填日期"]
        F2a --> F2b["冲突检测：红字提示排期冲突<br/>可选覆盖提交"]
        F2b --> F2c["航次进入审批流程<br/>（可点击查看审批时间轴）"]
    end

    A --> B
    B --> C
    C --> D
    D --> E
    E --> F
