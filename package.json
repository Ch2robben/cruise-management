{
  "name": "cruise-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:edgeone": "tsc -b && vite build --base /",
    "build:gitee": "tsc -b && vite build --base /cruise-project/",
    "build:gh-pages": "tsc -b && vite build --base /cruise-management/",
    "deploy:gh-pages": "npm run build:gh-pages && gh-pages -d dist",
    "deploy:gitee": "bash deploy.sh",
    "deploy:tencent": "bash deploy-tencent.sh",
    "deploy:edgeone": "bash deploy-edgeone.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
